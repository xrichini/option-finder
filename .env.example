# Configuration pour Options Squeeze Finder - Version FastAPI
# Clés API privées uniquement

# Clés Tradier
TRADIER_API_KEY_PRODUCTION=your-production-key-here
TRADIER_API_KEY_SANDBOX=your-sandbox-key-here

# Sandbox mode - set to 'true' for development/testing with sandbox API, 'false' for production
TRADIER_SANDBOX=false

# Clés autres services

OPENAI_API_KEY=your-openai-api-key-here
PERPLEXITY_API_KEY=your-perplexity-api-key-here
POLYGON_API_KEY=your-polygon-api-key-here